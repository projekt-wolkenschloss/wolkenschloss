{
    "$schema": "https://opencode.ai/config.json",
    "model": "anthropic/claude-sonnet-4-5",
    "autoupdate": "notify",
    "compaction": {
        "auto": true,
        "prune": true
    },
    "instructions": [],
    "permission": {
        "*": "allow",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow",
            "*secret*": "deny"
        },
        "bash": {
            "git *": "allow",
            "git commit *": "ask",
            "git push *": "deny",
            "ssh *": "ask",
            "scp *": "ask",
            "rsync *": "ask",
        },
        "edit": "ask"
    }
}